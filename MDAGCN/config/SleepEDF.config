[path]
data = ./data/SleepEDF_78/SleepEDF_78.npz
save = ./output_SleepEDF/

[feature]
channels = 4
fold = 10
epoch_f = 60
batch_size_f = 256
optimizer_f = adam
learn_rate_f = 0.0001

[train]
channels = 4
fold = 10
context = 5
epoch = 80
batch_size = 128
optimizer = adam
learn_rate = 0.0005

[model]
GLalpha = 0.0001
cheb_filters = 128
time_filters = 64
time_conv_strides = 1
time_conv_kernel = 3
num_block = 1
cheb_k = 3
l2 = 0.001
dropout = 0.6