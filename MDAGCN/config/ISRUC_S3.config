[path]
data = ./data/ISRUC_S3/ISRUC_S3.npz
save = ./output_ISRUC/

[feature]
channels = 10
fold = 10
epoch_f = 100
batch_size_f = 64
optimizer_f = adam
learn_rate_f = 0.0001

[train]
channels = 10
fold = 10
context = 5
epoch = 100
batch_size = 64
optimizer = adam
learn_rate = 0.00005


[model]
GLalpha = 0.00001
cheb_filters = 128
time_filters = 64
time_conv_strides = 1
time_conv_kernel = 3
num_block = 1
cheb_k = 3
l2 = 0.001
dropout = 0.6
